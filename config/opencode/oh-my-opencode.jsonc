{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "zai-coding-plan/glm-5.1",
    },
    "hephaestus": {
      "model": "zai-coding-plan/glm-5.1",
    },
    "prometheus": {
      "model": "zai-coding-plan/glm-5.1",
    },
    "atlas": {
      "model": "fireworks-ai/k2.5-flatrate",
    },
    "oracle": {
      "model": "zai-coding-plan/glm-5.1",
    },
    "librarian": {
      "model": "zai-coding-plan/glm-5-turbo",
    },
    "explore": {
      "model": "zai-coding-plan/glm-5-turbo",
    },
    "multimodal-looker": {
      "model": "fireworks-ai/k2.5-flatrate",
    },
    "metis": {
      "model": "zai-coding-plan/glm-5.1",
    },
    "momus": {
      "model": "zai-coding-plan/glm-5.1",
    },
  },
  "categories": {
    "visual-engineering": {
      "model": "zai-coding-plan/glm-5v-turbo",
    },
    "ultrabrain": {
      "model": "zai-coding-plan/glm-5.1",
    },
    "deep": {
      "model": "zai-coding-plan/glm-5.1",
    },
    "artistry": {
      "model": "zai-coding-plan/glm-5v-turbo",
    },
    "quick": {
      "model": "zai-coding-plan/glm-5.1",
    },
    "unspecified-low": {
      "model": "zai-coding-plan/glm-5-turbo",
    },
    "unspecified-high": {
      "model": "zai-coding-plan/glm-5.1",
    },
    "writing": {
      "model": "zai-coding-plan/glm-5.1",
    },
  },
  "background_task": {
    "defaultConcurrency": 20,
  },
}
