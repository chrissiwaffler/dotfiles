{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent@latest"],
  "theme": "monokai",
  "provider": {
    "amazon-bedrock": {
      "options": {
        "region": "eu-central-1",
      },
    },
    "zai-coding-plan": {
      "options": {
        "apiKey": "{env:ZAI_CODING_PLAN_API_KEY}",
      },
    },
    "fireworks-ai": {
      "options": {
        "apiKey": "{env:FIREWORKS_API_KEY}",
      },
      "models": {
        "fw-kimi-2.5-flatrate": {
          "id": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
          "name": "Kimi K2.5 TURBO flat rate",
        },
      },
    },
  },
}
