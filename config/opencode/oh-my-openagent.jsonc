{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "crofai/kimi-k2.6-precision",
    },
    "hephaestus": {
      "model": "crofai/deepseek-v4-pro-precision",
    },
    "prometheus": {
      "model": "crofai/kimi-k2.6-precision",
    },
    "atlas": {
      "model": "crofai/deepseek-v4-flash",
    },
    "oracle": {
      "model": "crofai/deepseek-v4-pro-precision",
    },
    "librarian": {
      "model": "crofai/deepseek-v4-flash",
    },
    "explore": {
      "model": "crofai/kimi-k2.6",
    },
    "multimodal-looker": {
      "model": "crofai/kimi-k2.6-precision",
    },
    "metis": {
      "model": "crofai/glm-5.1-precision",
    },
    "momus": {
      "model": "crofai/deepseek-v4-pro-precision",
    },
  },
  "categories": {
    "visual-engineering": {
      "model": "crofai/kimi-k2.6-precision",
    },
    "ultrabrain": {
      "model": "crofai/deepseek-v4-pro-precision",
    },
    "deep": {
      "model": "crofai/deepseek-v4-pro-precision",
    },
    "artistry": {
      "model": "crofai/kimi-k2.6-precision",
    },
    "quick": {
      "model": "crofai/kimi-k2.5-lightning",
    },
    "unspecified-low": {
      "model": "crofai/deepseek-v4-flash",
    },
    "unspecified-high": {
      "model": "crofai/deepseek-v4-pro-precision",
    },
    "writing": {
      "model": "crofai/deepseek-v4-pro",
    },
  },
  "background_task": {
    "defaultConcurrency": 20,
  },
}
