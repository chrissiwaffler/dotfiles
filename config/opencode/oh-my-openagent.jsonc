{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "crofai/kimi-k2.6-precision",
      "prompt_append": "For bigger tasks, consult prometheus and atlas for planning. Make extensive use of subagents for parallelized exploration. Make use of subagents since you can spawn up to 20 subagents in parallel at the same time to explore the codebase, documentation and the internet.",
    },
    "hephaestus": {
      "model": "crofai/deepseek-v4-pro-precision",
    },
    "prometheus": {
      "model": "crofai/kimi-k2.6-precision",
      "prompt_append": "Make use of subagents since you can spawn up to 20 subagents in parallel at the same time to explore the codebase, documentation and the internet.",
    },
    "atlas": {
      "model": "crofai/deepseek-v4-pro-precision",
    },
    "oracle": {
      "model": "crofai/deepseek-v4-pro-precision",
    },
    "librarian": {
      "model": "crofai/deepseek-v4-flash",
    },
    "explore": {
      "model": "crofai/kimi-k2.6",
    },
    "multimodal-looker": {
      "model": "crofai/kimi-k2.6-precision",
    },
    "metis": {
      "model": "crofai/glm-5.1-precision",
      "prompt_append": "Make use of subagents since you can spawn up to 20 subagents in parallel at the same time to explore the codebase, documentation and the internet.",
    },
    "momus": {
      "model": "crofai/deepseek-v4-pro-precision",
      "prompt_append": "Make use of subagents since you can spawn up to 20 subagents in parallel at the same time to explore the codebase, documentation and the internet.",
    },
  },
  "categories": {
    "visual-engineering": {
      "model": "crofai/kimi-k2.6-precision",
    },
    "ultrabrain": {
      "model": "crofai/deepseek-v4-pro-precision",
    },
    "deep": {
      "model": "crofai/deepseek-v4-pro-precision",
    },
    "artistry": {
      "model": "crofai/kimi-k2.6-precision",
    },
    "quick": {
      "model": "crofai/deepseek-v4-flash",
    },
    "unspecified-low": {
      "model": "crofai/deepseek-v4-flash",
    },
    "unspecified-high": {
      "model": "crofai/deepseek-v4-pro-precision",
    },
    "writing": {
      "model": "crofai/deepseek-v4-pro",
    },
  },
  "background_task": {
    "defaultConcurrency": 20,
  },
}
